<section id="faq" class="section bg-white">
  <div class="container-xl">
    <div class="max-w-3xl mx-auto">

      <div class="text-center mb-14 reveal">
        <span class="eyebrow">FAQ</span>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight mb-4">
          Questions?<br /><span class="text-gradient">We've got answers.</span>
        </h2>
        <p class="text-base text-gray-500">Can't find what you're looking for? <a href="#" class="text-purple-600 hover:underline font-medium">Chat with us →</a></p>
      </div>

      <%
        const faqs = [
          {
            q: 'How quickly can I deploy my first AI agent?',
            a: 'Most customers have their first agent live within 2 hours. Our setup wizard, pre-built templates, and 200+ integration connectors make it fast to go from sign-up to production. Enterprise customers also receive dedicated onboarding support.'
          },
          {
            q: 'Which AI models does Sidekick support?',
            a: "We support all major frontier models including Claude 4 (Anthropic), GPT-4o (OpenAI), Gemini 1.5 Pro (Google), Llama 3 (Meta), and Mistral. You can mix models across different agents or use your own fine-tuned models via our Bring-Your-Own-Model (BYOM) feature."
          },
          {
            q: 'Is my data secure and private?',
            a: "Absolutely. Sidekick is SOC 2 Type II certified, GDPR compliant, and HIPAA-eligible. All data is encrypted in transit (TLS 1.3) and at rest (AES-256). We never train on your data. Enterprise plans support private cloud or on-premise deployment for full data sovereignty."
          },
          {
            q: "What's the difference between Supervised and Autopilot mode?",
            a: "Supervised mode routes agent outputs to a human review queue before any action is taken — ideal for high-stakes or regulated workflows. Autopilot mode lets agents execute complete task sequences autonomously. You can configure per-agent, per-task-type, or per-confidence-level rules to mix both modes."
          },
          {
            q: 'Can I connect my existing tools and APIs?',
            a: "Yes. We offer 200+ native integrations (Salesforce, HubSpot, Slack, Notion, Stripe, SAP, and more) plus a universal API connector for any REST or GraphQL endpoint. We also support custom webhooks and Zapier/Make for no-code integration paths."
          },
          {
            q: 'What happens if an agent makes a mistake?',
            a: "Every agent action is logged with full context and a confidence score. You can set auto-rollback rules, configure error escalation paths, and replay any failed task with corrected context. Our audit trail gives you complete visibility and accountability."
          },
          {
            q: 'Do you offer volume pricing for high task usage?',
            a: "Yes. Enterprise plans include custom volume-based pricing for task runs. Contact our sales team and we can build a package around your expected throughput, model usage mix, and deployment requirements. We offer annual contracts with significant savings."
          },
          {
            q: 'What support options are available?',
            a: "Starter plans include email and in-app chat support. Growth plans include priority 24/7 support with a 4-hour SLA. Enterprise plans include a dedicated Customer Success Manager, a private Slack channel, and on-call engineering support."
          },
        ];
      %>

      <div id="faq-list" class="flex flex-col gap-3">
        <% faqs.forEach((faq, i) => { %>
        <div class="faq-item reveal reveal-delay-<%= (i % 3) + 1 %>">
          <button class="faq-trigger" aria-expanded="false" data-faq-index="<%= i %>">
            <span><%= faq.q %></span>
            <svg class="faq-icon w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </button>
          <div class="faq-body" id="faq-body-<%= i %>">
            <p class="px-6 pb-6 text-sm text-gray-500 leading-relaxed"><%= faq.a %></p>
          </div>
        </div>
        <% }) %>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
