<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= description %>" />
  <title><%= title %></title>
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="antialiased overflow-x-hidden">

<%- include('partials/nav') %>

<!-- ══════════════════════════════════════════════════════════
     §1  HERO SECTION
══════════════════════════════════════════════════════════ -->
<section id="hero" class="relative min-h-[92vh] flex flex-col items-center justify-center bg-gradient-hero overflow-hidden pt-8 pb-16">

  <!-- Ambient blobs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-32 -left-32 w-[600px] h-[600px] rounded-full bg-purple-200/25 blur-[120px]"></div>
    <div class="absolute -bottom-20 -right-20 w-[500px] h-[500px] rounded-full bg-pink-200/25 blur-[100px]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] rounded-full bg-blue-100/20 blur-[140px]"></div>
    <!-- Grid overlay -->
    <div class="absolute inset-0 hero-grid-shimmer opacity-60"></div>
  </div>

  <div class="container-xl relative z-10 text-center flex flex-col items-center gap-8">

    <!-- Eyebrow badge -->
    <div class="reveal" data-delay="0">
      <span class="banner-pill">
        <span class="w-1.5 h-1.5 rounded-full bg-purple-500 animate-pulse-slow"></span>
        Powered by cutting-edge agentic AI
      </span>
    </div>

    <!-- Headline -->
    <div class="reveal reveal-delay-1 max-w-4xl">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tightest text-gray-900 leading-[1.05]">
        Supercharge your business<br />
        productivity with
        <span class="text-gradient-warm"> AI Sidekicks</span>
      </h1>
    </div>

    <!-- Subheadline -->
    <div class="reveal reveal-delay-2 max-w-2xl">
      <p class="text-lg sm:text-xl text-gray-500 leading-relaxed font-normal">
        Deploy autonomous AI agents, automate end-to-end workflows, and scale intelligent operations — without adding headcount.
      </p>
    </div>

    <!-- Action buttons -->
    <div class="reveal reveal-delay-3 flex flex-col sm:flex-row gap-4 items-center">
      <a href="#pricing" class="btn-primary px-7 py-3.5 text-base">
        Start Free Trial
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a href="#features" class="btn-ghost px-7 py-3.5 text-base gap-2">
        <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
        </svg>
        Watch Demo
      </a>
    </div>

    <!-- Social proof strip -->
    <div class="reveal reveal-delay-4 flex flex-col sm:flex-row items-center gap-3 sm:gap-6 text-sm text-gray-500">
      <div class="flex -space-x-2.5">
        <% const avatarColors = ['bg-purple-400','bg-pink-400','bg-blue-400','bg-emerald-400','bg-amber-400']; %>
        <% avatarColors.forEach((c, i) => { %>
        <div class="w-8 h-8 rounded-full <%= c %> border-2 border-white flex items-center justify-center text-white text-xs font-bold ring-1 ring-white/50">
          <%= String.fromCharCode(65 + i) %>
        </div>
        <% }) %>
      </div>
      <span><strong class="text-gray-900 font-semibold">2,400+</strong> businesses automated</span>
      <span class="hidden sm:block text-gray-300">|</span>
      <span class="flex items-center gap-1">
        <% for(let s=0;s<5;s++) { %>
        <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <% } %>
        <strong class="text-gray-900 font-semibold ml-1">4.9/5</strong> on G2
      </span>
    </div>

    <!-- Hero dashboard mockup -->
    <div class="reveal reveal-delay-4 w-full max-w-5xl mt-4 animate-float">
      <div class="relative rounded-3xl border border-gray-200/80 bg-white shadow-card-lg overflow-hidden">
        <!-- Mock browser bar -->
        <div class="flex items-center gap-2 px-5 py-3.5 border-b border-gray-100 bg-gray-50/80">
          <span class="w-3 h-3 rounded-full bg-red-300"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-300"></span>
          <span class="w-3 h-3 rounded-full bg-green-300"></span>
          <div class="mx-auto flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-4 py-1 text-xs text-gray-400 w-56">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
            app.sidekick.ai/dashboard
          </div>
        </div>
        <!-- Mock dashboard content -->
        <div class="p-6 bg-gradient-to-br from-white to-gray-50/60 min-h-[320px] grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Stat cards -->
          <% const stats = [
            { label: 'Tasks Automated', val: '14,821', delta: '+12.4%', color: 'text-emerald-500', icon: '⚡' },
            { label: 'Hours Saved',     val: '3,290',  delta: '+8.7%',  color: 'text-blue-500',    icon: '⏱' },
            { label: 'Active Agents',   val: '47',     delta: '+3',     color: 'text-purple-500',  icon: '🤖' },
          ]; %>
          <% stats.forEach(s => { %>
          <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-card flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-xs font-medium text-gray-500"><%= s.label %></span>
              <span class="text-base"><%= s.icon %></span>
            </div>
            <p class="text-2xl font-bold text-gray-900 tracking-tight"><%= s.val %></p>
            <p class="text-xs font-semibold <%= s.color %>"><%= s.delta %> this week</p>
          </div>
          <% }) %>
          <!-- Activity feed (spans 2 cols on sm) -->
          <div class="sm:col-span-2 bg-white rounded-2xl border border-gray-100 p-5 shadow-card">
            <p class="text-xs font-semibold text-gray-500 mb-4 uppercase tracking-wider">Live Agent Feed</p>
            <% const feed = [
              { agent: 'EmailSorter v2',   action: 'Classified 42 emails',      time: '2s ago',  status: 'done'    },
              { agent: 'LeadQualifier',    action: 'Scored 12 inbound leads',   time: '18s ago', status: 'done'    },
              { agent: 'InvoiceBot',       action: 'Processing Q2 batch…',      time: 'now',     status: 'running' },
              { agent: 'SupportAgent',     action: 'Resolved 7 tickets',        time: '1m ago',  status: 'done'    },
            ]; %>
            <ul class="flex flex-col gap-3">
              <% feed.forEach(f => { %>
              <li class="flex items-center gap-3 text-sm">
                <span class="w-2 h-2 rounded-full flex-shrink-0 <%= f.status === 'running' ? 'bg-emerald-400 animate-pulse' : 'bg-gray-300' %>"></span>
                <span class="font-semibold text-gray-700 w-32 flex-shrink-0 truncate"><%= f.agent %></span>
                <span class="text-gray-500 flex-1 truncate"><%= f.action %></span>
                <span class="text-gray-400 text-xs flex-shrink-0"><%= f.time %></span>
              </li>
              <% }) %>
            </ul>
          </div>
          <!-- Workflow mini-chart placeholder -->
          <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-card flex flex-col gap-3">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Workflow Health</p>
            <div class="flex items-end gap-1.5 h-16 mt-auto">
              <% const bars = [60,75,55,90,80,95,88]; %>
              <% bars.forEach(b => { %>
              <div class="flex-1 rounded-t-sm bg-gradient-to-t from-purple-400 to-pink-300 transition-all duration-300 hover:from-purple-500 hover:to-pink-400" style="height:<%= b %>%"></div>
              <% }) %>
            </div>
            <p class="text-xs text-gray-400">Last 7 days</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Trusted logos row -->
    <div class="reveal reveal-delay-4 mt-6 w-full">
      <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-6">Trusted by forward-thinking teams at</p>
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12 opacity-40 grayscale">
        <% const logos = ['Acme Corp','Vercel','Linear','Stripe','Notion','Figma']; %>
        <% logos.forEach(l => { %>
        <span class="text-sm sm:text-base font-bold text-gray-700 tracking-tight"><%= l %></span>
        <% }) %>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════════════════
     §2  BENTO GRID FEATURES
══════════════════════════════════════════════════════════ -->
<section id="features" class="section bg-gray-50/70">
  <div class="container-xl">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <span class="eyebrow">Platform capabilities</span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight mb-4">
        Everything you need to run<br />
        <span class="text-gradient">AI at scale</span>
      </h2>
      <p class="text-base sm:text-lg text-gray-500 leading-relaxed">
        A unified platform for building, deploying, and managing intelligent agents that work around the clock.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 auto-rows-auto">

      <!-- Card 1 – large hero card -->
      <div class="bento-card lg:col-span-2 bg-gradient-to-br from-purple-600 to-fuchsia-600 text-white border-0 reveal">
        <div class="icon-wrap bg-white/20 backdrop-blur-sm">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold">Custom AI Agent Deployment</h3>
        <p class="text-purple-100 text-sm leading-relaxed max-w-sm">
          Spin up purpose-built AI agents configured for your exact workflows. From customer support to internal ops — your sidekick, your rules.
        </p>
        <div class="mt-auto flex flex-wrap gap-2">
          <% ['GPT-4o', 'Claude 4', 'Gemini', 'Llama 3'].forEach(t => { %>
          <span class="px-3 py-1 rounded-full bg-white/15 text-white text-xs font-medium backdrop-blur-sm"><%= t %></span>
          <% }) %>
        </div>
        <!-- Decorative grid in card -->
        <div class="absolute right-0 bottom-0 w-48 h-48 opacity-10 pointer-events-none hero-grid-shimmer rounded-3xl"></div>
      </div>

      <!-- Card 2 -->
      <div class="bento-card reveal reveal-delay-1">
        <div class="icon-wrap bg-gradient-to-br from-blue-500 to-cyan-400">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Workflow Automation</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Chain triggers, conditions, and actions into powerful automated pipelines — no code required.
        </p>
        <!-- Mini pipeline viz -->
        <div class="flex items-center gap-2 mt-2 flex-wrap">
          <% ['Trigger','Filter','Transform','Notify'].forEach((step, i) => { %>
          <div class="flex items-center gap-2">
            <span class="px-2.5 py-1 rounded-lg bg-blue-50 text-blue-700 text-xs font-semibold border border-blue-100"><%= step %></span>
            <% if(i < 3) { %>
            <svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bento-card reveal reveal-delay-2">
        <div class="icon-wrap bg-gradient-to-br from-emerald-500 to-teal-400">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Multi-Cloud Orchestration</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Unify agents across AWS, GCP, Azure, and your private infrastructure from a single control plane.
        </p>
        <div class="flex gap-2 mt-auto">
          <% ['AWS','GCP','Azure','On-Prem'].forEach(c => { %>
          <span class="tag"><%= c %></span>
          <% }) %>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="bento-card reveal reveal-delay-3">
        <div class="icon-wrap bg-gradient-to-br from-orange-400 to-rose-400">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Real-Time Analytics</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Monitor agent performance, task throughput, and cost efficiency with live dashboards and alerts.
        </p>
        <!-- Sparkline bars -->
        <div class="flex items-end gap-1 h-10 mt-auto">
          <% [40,65,50,80,70,90,75,95,88].forEach(h => { %>
          <div class="flex-1 rounded-sm bg-gradient-to-t from-orange-400 to-rose-300" style="height:<%= h %>%"></div>
          <% }) %>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="bento-card reveal reveal-delay-1">
        <div class="icon-wrap bg-gradient-to-br from-violet-500 to-purple-600">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">1-Click Integrations</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          Connect to 200+ tools including Slack, HubSpot, Salesforce, Notion, and your custom APIs instantly.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-auto">
          <% ['Slack','Notion','HubSpot','Salesforce','Zapier','+195'].forEach(app => { %>
          <span class="tag"><%= app %></span>
          <% }) %>
        </div>
      </div>

      <!-- Card 6 – wide bottom card -->
      <div class="bento-card sm:col-span-2 lg:col-span-1 bg-gradient-warm border-0 reveal reveal-delay-2">
        <div class="icon-wrap bg-white/70">
          <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Enterprise-Grade Security</h3>
        <p class="text-sm text-gray-500 leading-relaxed">
          SOC 2 Type II certified. End-to-end encryption, RBAC, audit logs, and private cloud deployment available.
        </p>
        <div class="flex gap-2 mt-auto flex-wrap">
          <% ['SOC 2','GDPR','HIPAA','ISO 27001'].forEach(b => { %>
          <span class="px-3 py-1 rounded-full bg-white/80 text-gray-700 text-xs font-semibold border border-orange-100"><%= b %></span>
          <% }) %>
        </div>
      </div>

    </div><!-- /bento grid -->
  </div>
</section>


<!-- ══════════════════════════════════════════════════════════
     §3  SOLUTION BLOCKS (alternating single + dual content)
══════════════════════════════════════════════════════════ -->
<section id="solutions" class="section bg-white">
  <div class="container-xl flex flex-col gap-24">

    <!-- Block A – left text / right visual (single content) -->
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Text -->
      <div class="flex-1 flex flex-col gap-6 reveal">
        <span class="eyebrow">For Enterprise Teams</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 tracking-tight leading-tight">
          Seamless enterprise<br />integration, zero friction.
        </h2>
        <p class="text-base sm:text-lg text-gray-500 leading-relaxed max-w-lg">
          Connect Sidekick directly to your existing ERP, CRM, and data infrastructure. Our agents ingest, process, and act on your data without manual intervention.
        </p>
        <ul class="flex flex-col gap-3 text-sm text-gray-700">
          <% [
            'Pre-built connectors for SAP, Salesforce, Oracle & more',
            'Secure on-prem & VPC deployment options',
            'Custom API bridge for legacy systems',
            'Real-time bi-directional data sync',
          ].forEach(item => { %>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-purple-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= item %>
          </li>
          <% }) %>
        </ul>
        <div class="flex gap-3 pt-2">
          <a href="#" class="btn-primary">Explore Integrations</a>
          <a href="#" class="btn-ghost">View Docs</a>
        </div>
      </div>
      <!-- Visual card -->
      <div class="flex-1 reveal reveal-delay-2">
        <div class="glass-card p-8 bg-gradient-to-br from-purple-50 to-blue-50/50">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-gradient-cta flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">Integration Hub</p>
              <p class="text-xs text-gray-500">200+ active connectors</p>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <% [
              {name:'Salesforce',color:'bg-blue-100 text-blue-700'},
              {name:'SAP',color:'bg-green-100 text-green-700'},
              {name:'HubSpot',color:'bg-orange-100 text-orange-700'},
              {name:'Stripe',color:'bg-purple-100 text-purple-700'},
              {name:'Notion',color:'bg-gray-100 text-gray-700'},
              {name:'Slack',color:'bg-pink-100 text-pink-700'},
            ].forEach(app => { %>
            <div class="rounded-xl border border-gray-100 bg-white p-3 text-center shadow-card">
              <div class="w-8 h-8 rounded-lg <%= app.color %> mx-auto mb-2 flex items-center justify-center text-xs font-bold">
                <%= app.name.slice(0,2) %>
              </div>
              <p class="text-xs font-medium text-gray-700"><%= app.name %></p>
