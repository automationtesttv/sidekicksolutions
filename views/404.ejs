<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="antialiased bg-gradient-hero min-h-screen flex flex-col">
  <div class="flex-1 flex flex-col items-center justify-center text-center px-4 py-20">
    <div class="w-20 h-20 rounded-3xl bg-gradient-cta flex items-center justify-center shadow-glow mb-8 animate-float">
      <svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
      </svg>
    </div>
    <p class="text-sm font-semibold uppercase tracking-widest text-purple-500 mb-3">404 — Not Found</p>
    <h1 class="text-5xl sm:text-6xl font-extrabold text-gray-900 tracking-tight mb-4">Page not found.</h1>
    <p class="text-lg text-gray-500 max-w-md mb-10">Looks like your Sidekick couldn't locate this page. Let's get you back on track.</p>
    <a href="/" class="btn-primary px-8 py-3.5 text-base">← Back to Home</a>
  </div>
</body>
</html>
