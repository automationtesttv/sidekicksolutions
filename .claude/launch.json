{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Express Dev Server (nodemon)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Express Prod Server (node)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "Tailwind CSS Watcher",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "watch:css"],
      "port": null
    },
    {
      "name": "Tailwind CSS Build (minified)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build:css"],
      "port": null
    }
  ]
}
