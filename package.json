{
  "name": "sidekick-solutions",
  "version": "1.0.0",
  "description": "Sidekick Solutions – AI-powered agentic systems and automation for modern businesses.",
  "main": "server.js",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify && node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync('dist',{recursive:true});fs.cpSync('public',require('path').join('dist','public'),{recursive:true});fs.writeFileSync('dist/.hostinger','ok');\"",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1"
  }
}
